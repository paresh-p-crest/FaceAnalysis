# ── Frontend (Next.js) ──────────────────────────────────────────────────────
# URL of Python FastAPI backend (no trailing slash)
# Local: http://localhost:8000
# When set, analysis runs on server and saves to MongoDB
NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev-only UI shortcuts (skip questionnaire with sample data). NEVER enable in production.
# NEXT_PUBLIC_DEV_SHORTCUTS=true

# ── Backend (Python FastAPI) ────────────────────────────────────────────────
# MongoDB Atlas connection string (must include database name)
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/myface?retryWrites=true&w=majority
MONGODB_URI=
AUTH_SECRET=change-me-to-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
CORS_ORIGIN_REGEX=https://.*\.(replit\.dev|repl\.co)

# Optional — LLM for AI narrative (admin review + report summary)
# Use Groq for free-tier testing: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_REPORT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
PORT=3000
BACKEND_PORT=8000
PUBLIC_APP_URL=http://localhost:3000

# Payments (optional until Sprint 8 live payment testing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email / notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@myface.local
SMTP_FROM_NAME=MyFace

# Frontend analytics
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=

# Protocol JSON storage (local dev — mirrors photo storage pattern)
PROTOCOL_STORAGE_BACKEND=local
# PROTOCOL_UPLOAD_ROOT=public/uploads/assessments
# PROTOCOL_PUBLIC_URL_PREFIX=/uploads/assessments

# App mode and AWS/OpenAI keys can still be set in the Settings UI (browser localStorage).
