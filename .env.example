# =============================================================================
# MyFace — environment template
# Copy to project root:  cp .env.example .env
# Backend (uvicorn) and Next.js both read the root .env file.
# Never commit .env — it contains secrets.
# =============================================================================

# --- Frontend (Next.js) ---
# Python FastAPI base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Analytics (optional)
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_GTM_ID=

# Dev-only UI shortcuts — NEVER enable in production
# NEXT_PUBLIC_DEV_SHORTCUTS=true
# NEXT_PUBLIC_DEV_AUTO_APPROVE=true

# --- Backend — database & auth ---
# MongoDB Atlas URI (must include database name)
# mongodb+srv://USER:PASSWORD@cluster.mongodb.net/myface?retryWrites=true&w=majority
MONGODB_URI=
AUTH_SECRET=change-me-to-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Uvicorn port when using `python -m backend.main` (CLI --port overrides)
PORT=8000
# Frontend origin for payment return URLs and email links
PUBLIC_APP_URL=http://localhost:3000

# --- Backend — CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
CORS_ORIGIN_REGEX=https://.*\.(replit\.dev|repl\.co)

# Dev-only — auto-approve assessments + skip review gate. NEVER in production
# DEV_AUTO_APPROVE_REPORTS=true

# --- LLM — narratives, protocol, Beauty Assistant ---
# LOG_LEVEL=INFO
# Text AI provider: groq (free tier) or openai
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_REPORT_MODEL=gpt-4o-mini
# AI visuals (hair/outfit/aging previews) require OPENAI_API_KEY + gpt-image-1
OPENAI_IMAGE_MODEL=gpt-image-1
# --- Payments (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Email / notifications (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@myface.local
SMTP_FROM_NAME=MyFace

# --- Storage overrides (optional; local defaults under public/uploads/assessments) ---
# PHOTO_STORAGE_BACKEND=local
# PHOTO_UPLOAD_ROOT=public/uploads/assessments
# PHOTO_PUBLIC_URL_PREFIX=/uploads/assessments
# PROTOCOL_STORAGE_BACKEND=local
# PROTOCOL_UPLOAD_ROOT=public/uploads/assessments
# PROTOCOL_PUBLIC_URL_PREFIX=/uploads/assessments
