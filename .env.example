# =============================================================================
# MyFace — environment template
# Copy to project root:  cp .env.example .env
# Backend (uvicorn) and Next.js both read the root .env file.
# Never commit .env — it contains secrets.
# =============================================================================

# --- Frontend (Next.js) ---
# Python FastAPI base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Analytics (optional)
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_GTM_ID=

# Dev-only UI shortcuts — NEVER enable in production
# NEXT_PUBLIC_DEV_SHORTCUTS=true
# NEXT_PUBLIC_DEV_AUTO_APPROVE=true

# --- Backend — database & auth ---
# PostgreSQL connection string (asyncpg). Examples:
# postgresql://USER:PASSWORD@localhost:5432/myface # local — SSL off automatically
# postgres://USER:PASSWORD@HOST:5432/myface?sslmode=require # remote managed
DATABASE_URL=
AUTH_SECRET=change-me-to-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Uvicorn port when using `python -m backend.main` (CLI --port overrides)
PORT=8000
# Frontend origin for payment return URLs and email links
PUBLIC_APP_URL=http://localhost:3000

# --- Backend — CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
CORS_ORIGIN_REGEX=https://.*\.(replit\.dev|repl\.co)

# Dev-only — auto-approve assessments + skip review gate. NEVER in production
# DEV_AUTO_APPROVE_REPORTS=true

# --- LLM — narratives, protocol, Beauty Assistant ---
# LOG_LEVEL=INFO
# Text AI provider: groq | openai | openrouter
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_REPORT_MODEL=gpt-4o-mini
# OpenRouter (OpenAI-compatible). Free models use :free suffix — still rate-limited
# (~20 RPM / 50 RPD free; ~1000 RPD after $10 credits). Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional attribution headers (defaults: PUBLIC_APP_URL + "MyFace")
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=MyFace
# Unified max completion tokens for all backend LLM calls (default 8000)
# LLM_MAX_OUTPUT_TOKENS=8000
# Feature narrative hard-reject attempts (default 3 total) and 429 backoff (3 extras from 30s)
# FEATURE_NARRATIVE_MAX_ATTEMPTS=3
# FEATURE_NARRATIVE_RATE_LIMIT_RETRIES=3
# FEATURE_NARRATIVE_RATE_LIMIT_BACKOFF_SEC=30
# --- Image generation — AI visuals + generative projected AFTER face ---
# Provider-agnostic (backend/image_client.py). Provider resolves as:
#   IMAGE_PROVIDER (openai|openrouter) → LLM_PROVIDER → key presence.
# Leave IMAGE_PROVIDER unset to reuse LLM_PROVIDER for images too.
# IMAGE_PROVIDER=openrouter
# OpenAI path: /v1/images/edits (multipart). Needs OPENAI_API_KEY.
OPENAI_IMAGE_MODEL=gpt-image-1
# OpenRouter path: /v1/chat/completions with image modalities. Needs OPENROUTER_API_KEY.
# Pick any image-output model (see https://openrouter.ai/models?output_modalities=image).
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# --- Payments (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Email / notifications (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@myface.local
SMTP_FROM_NAME=MyFace

# --- Async assessment pipeline + face parsing (optional) ---
# PIPELINE_WORKER_ENABLED=true
# PIPELINE_POLL_INTERVAL_SEC=3
# FACE_PARSING_ENABLED=true
# PROJECTED_AFTER_ENABLED=false
# Face-parsing deps (torch + torchvision + transformers) are included in
# root requirements.txt: python -m pip install -r requirements.txt

# --- Media storage (poses, parsing crops, projected AFTER, protocol JSON) ---
# One interface, two backends (backend/media_storage.py). Served to the browser
# at /api/media/... in both cases, so URLs are identical locally and on Replit.
#   local  = filesystem (dev/Windows). No cloud creds needed.
#   replit = Replit Object Storage (Replit runtime only; uses .replit
#            [objectStorage] defaultBucketID automatically).
# Unset = auto-detect: replit inside a Replit env, else local.
MEDIA_STORAGE_BACKEND=local
# Local backend root dir (default: <repo>/var/media)
# MEDIA_LOCAL_ROOT=var/media
# Override the Replit bucket instead of the .replit default (optional)
# REPLIT_DEFAULT_BUCKET_ID=replit-objstore-xxxxxxxx
