modules = ["nodejs-20", "python-3.11", "web", "bash", "nix", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Python Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload --reload-dir backend"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/myface: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/myface"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/myface run dev --port 3000"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "postgresql", "tcl", "tk", "zlib"]

[objectStorage]
defaultBucketID = "replit-objstore-87409622-8841-4e00-9cf9-12d6601966e3"

[userenv]

[userenv.shared]
ADMIN_EMAIL = "admin@myface.local"
CORS_ORIGINS = "http://localhost:3000,http://127.0.0.1:3000"
CORS_ORIGIN_REGEX = 'https://.*\.(replit\.dev|repl\.co)'
LLM_PROVIDER = "groq"
MEDIA_STORAGE_BACKEND = "replit"
PUBLIC_APP_URL = "http://localhost:3000"
